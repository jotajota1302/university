{
  "version": 2,
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/v1/checkout/create-session", "destination": "/api/checkout" },
    { "source": "/v1/health", "destination": "/api/health" }
  ]
}
