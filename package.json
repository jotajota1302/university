{
  "name": "openclaw-university",
  "version": "1.0.0",
  "description": "OpenClaw University Monorepo",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "cd api && ts-node src/server.ts",
    "build": "cd api && npm install && npm run build && rm -rf ../dist && cp -R dist ../dist",
