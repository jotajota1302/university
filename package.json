    "test": "cd api && npm test"
  },
  "dependencies": {
    "@types/node": "^20.19.33",
    "fastify": "^4.28.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "vitest": "^2.1.4"
  }
}
